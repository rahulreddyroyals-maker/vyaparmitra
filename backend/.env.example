# VyaparMitra Backend - Environment Variables
# Copy to .env and fill in values

# Supabase - use SERVICE ROLE key (not anon key) for backend
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# WATI WhatsApp API
WATI_API_URL=https://live-server-XXXXX.wati.io
WATI_API_TOKEN=your_wati_bearer_token

# Webhook verification token (set same value in WATI dashboard)
WA_VERIFY_TOKEN=vyaparmitra2024

PORT=3001
